diff --git a/scripts/start-local-dev.sh b/scripts/start-local-dev.sh
new file mode 100755
index 000000000..59f9fa6f5
--- /dev/null
+++ b/scripts/start-local-dev.sh
@@ -0,0 +1,78 @@
+#!/usr/bin/env bash
+
+set -euo pipefail
+
+ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
+REPO_ROOT="$(cd "${ROOT_DIR}/../.." && pwd)"
+DEPLOY_DIR="${REPO_ROOT}/deploy"
+ENV_FILE="${REPO_ROOT}/.env"
+CERT_PATH="${DEPLOY_DIR}/generated/localhost-cert.pem"
+SERVER_CONFIG_PATH="${DEPLOY_DIR}/generated/signal-server.yml"
+
+SIGNAL_HTTPS_PORT=9443
+if [[ -f "${ENV_FILE}" ]]; then
+  # shellcheck disable=SC1090
+  source "${ENV_FILE}"
+fi
+
+LOCAL_URL="${LOCAL_SIGNAL_DESKTOP_URL:-https://localhost:${SIGNAL_HTTPS_PORT:-9443}}"
+
+if [[ -s "${HOME}/.nvm/nvm.sh" ]]; then
+  # shellcheck disable=SC1090
+  source "${HOME}/.nvm/nvm.sh"
+  nvm use >/dev/null
+fi
+
+if [[ ! -f "${CERT_PATH}" ]]; then
+  echo "Missing ${CERT_PATH}" >&2
+  echo "Run: ${REPO_ROOT}/scripts/generate-localhost-cert.sh" >&2
+  exit 1
+fi
+
+if [[ ! -f "${SERVER_CONFIG_PATH}" ]]; then
+  echo "Missing ${SERVER_CONFIG_PATH}" >&2
+  echo "Run: ${REPO_ROOT}/scripts/render-signal-config.sh" >&2
+  exit 1
+fi
+
+NODE_CONFIG="$(
+  node - "${CERT_PATH}" "${SERVER_CONFIG_PATH}" "${LOCAL_URL}" <<'EOF'
+const fs = require('node:fs');
+
+const [, , certPath, serverConfigPath, localUrl] = process.argv;
+const certPem = fs.readFileSync(certPath, 'utf8');
+const serverConfig = fs.readFileSync(serverConfigPath, 'utf8');
+const serverPublicMatch = serverConfig.match(/^\s*serverPublic:\s*(\S+)\s*$/m);
+
+if (!serverPublicMatch) {
+  console.error(`Could not find zkConfig.serverPublic in ${serverConfigPath}`);
+  process.exit(1);
+}
+
+const overrides = {
+  serverUrl: localUrl,
+  storageUrl: localUrl,
+  directoryUrl: localUrl,
+  sfuUrl: `${localUrl}/`,
+  cdn: {
+    '0': localUrl,
+    '2': localUrl,
+    '3': localUrl,
+  },
+  challengeUrl: localUrl,
+  registrationChallengeUrl: localUrl,
+  certificateAuthority: certPem,
+  serverPublicParams: serverPublicMatch[1],
+  hardcodedCaptchaForLocalTestingOnly: 'noop.noop.registration.localtest',
+  openDevTools: true,
+};
+
+process.stdout.write(JSON.stringify(overrides));
+EOF
+)"
+
+export NODE_ENV=development
+export SIGNAL_ENABLE_HTTP=1
+export NODE_CONFIG
+
+echo "Starting Signal Desktop against ${LOCAL_URL}"
+cd "${ROOT_DIR}"
+exec pnpm start
